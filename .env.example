# LawFlow 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ===== AI 服务配置 =====
# AI 提供商: volcengine 或 openrouter
AI_PROVIDER=volcengine

# 火山引擎配置
VOLCENGINE_KEY=your_volcengine_key_here
VOLCENGINE_MODEL=doubao-seed-2-0-lite-260215
VOLCENGINE_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions
VOLCENGINE_REASONING=minimal

# OpenRouter 配置 (备用)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemma-3-4b-it:free

# ===== OCR 服务配置 =====
# 腾讯云 OCR
TENCENT_SECRET_ID=your_tencent_secret_id_here
TENCENT_SECRET_KEY=your_tencent_secret_key_here
TENCENT_OCR_REGION=ap-guangzhou

# ===== CORS 配置 =====
# 允许的跨域来源，多个用逗号分隔，开发环境用 *，生产环境应限制域名
# 示例: https://example.com,https://app.example.com
CORS_ALLOWED_ORIGINS=*

# ===== 后端服务配置 =====
BACKEND_URL=http://localhost:3457
API_TIMEOUT=30000
API_MAX_RETRIES=3
API_RETRY_DELAY=1000

# ===== 文件上传配置 =====
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=.pdf,.png,.jpg,.jpeg

# ===== 存储配置 =====
MAX_HISTORY_ITEMS=20
UPLOAD_RETENTION_DAYS=7
MAX_UPLOAD_FILES=20
MAX_UPLOAD_TOTAL_GB=1
STORAGE_KEY_PREFIX=lw_

# ===== 律所信息配置 =====
LAW_FIRM_NAME=安徽国恒律师事务所
LAW_FIRM_ATTORNEY=赵光辉
LAW_FIRM_YEARS=20
LAW_FIRM_ADDRESS=
LAW_FIRM_PHONE=

# ===== 功能开关 =====
FEATURE_ASYNC_TASKS=true
FEATURE_STREAMING=true
FEATURE_TASK_PROGRESS=true
DEBUG_MODE=false

# ===== UI 配置 =====
DEFAULT_LOCALE=zh-CN
THEME_PRIMARY_COLOR=#0071E3
THEME_BORDER_RADIUS=18px
UI_ANIMATION=true
UI_ANIMATION_DURATION=300
